\citation{golds}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-seed ADP reduction for every benchmark; this figure carries the per-benchmark results in place of a table. Each benchmark shows its three training-seed outcomes (dots; seeds 7/42/123), the median (tick), and the min--max range (line) --- raw seeds rather than mean $\pm $ SD, which three runs cannot justify. In-pool fitting is seed-sensitive on two benchmarks, \texttt  {or1200} and \texttt  {boundtop} (shaded), whose ranges span $\sim $28 and $\sim $29 points; every other in-pool benchmark and all six held-out (zero-shot) benchmarks are tight (range $\le 12$ points). The held-out group is more seed-stable than in-pool fitting.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:seedvar}{{2}{5}{Per-seed ADP reduction for every benchmark; this figure carries the per-benchmark results in place of a table. Each benchmark shows its three training-seed outcomes (dots; seeds 7/42/123), the median (tick), and the min--max range (line) --- raw seeds rather than mean $\pm $ SD, which three runs cannot justify. In-pool fitting is seed-sensitive on two benchmarks, \texttt {or1200} and \texttt {boundtop} (shaded), whose ranges span $\sim $28 and $\sim $29 points; every other in-pool benchmark and all six held-out (zero-shot) benchmarks are tight (range $\le 12$ points). The held-out group is more seed-stable than in-pool fitting}{figure.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Same destination, very different search cost, on \texttt  {softmax} (baseline ADP $=3.58\!\times \!10^6$; held out of RL training). GA: population 8, $\le $500 generations, early-stop patience 50, run to convergence. RL zero-shot is a single deterministic rollout (seed 42); RL fine-tuned continues the 11-benchmark policy on \texttt  {softmax}. Wall-clock is on the same 24-core machine; the GA and the RL fine-tune use the same eight parallel workers.}}{5}{table.caption.6}\protected@file@percent }
\newlabel{tab:ga}{{2}{5}{Same destination, very different search cost, on \texttt {softmax} (baseline ADP $=3.58\!\times \!10^6$; held out of RL training). GA: population 8, $\le $500 generations, early-stop patience 50, run to convergence. RL zero-shot is a single deterministic rollout (seed 42); RL fine-tuned continues the 11-benchmark policy on \texttt {softmax}. Wall-clock is on the same 24-core machine; the GA and the RL fine-tune use the same eight parallel workers}{table.caption.6}{}}
